### Variables
@baseUrl = http://localhost:8080
@productId = 1
@orderId = 1

### Prepare product for order
POST {{baseUrl}}/products
Content-Type: application/json

{
  "name": "Keyboard",
  "price": 30000,
  "stockQuantity": 10
}

### Create order
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 1
}

### Get order
GET {{baseUrl}}/orders/{{orderId}}

### Get orders
GET {{baseUrl}}/orders?page=0&size=10

### Update ordered product name
PUT {{baseUrl}}/products/{{productId}}
Content-Type: application/json

{
  "name": "Mechanical Keyboard",
  "price": 30000,
  "stockQuantity": 1
}

### Get order after product name update
GET {{baseUrl}}/orders/{{orderId}}

### Create order with missing product
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "productId": 999999,
  "quantity": 1
}

### Create order with insufficient stock
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "productId": {{productId}},
  "quantity": 999999
}

### Get missing order
GET {{baseUrl}}/orders/999999
